# Required: Thor IP address reachable from host (Ethernet or Wi-Fi)
THOR_IP=192.168.1.50

# Host-local service ports
HOST_VITE_PORT=5173
HOST_API_PORT=8000
HOST_RERUN_GRPC_PORT=9876
HOST_RERUN_WEB_PORT=9090

# Frontend runtime endpoints
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional robot runner on host
RUN_ROBOT_RUNNER=0
ROBOT_HEARTBEAT_PATH=data_logs/.robot_heartbeat.json
RERUN_GRPC_URL=rerun+http://127.0.0.1:9876/proxy
RERUN_WEB_URL=http://localhost:9090
