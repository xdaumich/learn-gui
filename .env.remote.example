# MediaMTX binary and config path on Thor
MEDIAMTX_BIN=mediamtx
MEDIAMTX_CONFIG_PATH=mediamtx.yml

# MediaMTX listener ports on Thor
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_WHEP_PORT=8889
MEDIAMTX_API_PORT=9997
WEBRTC_ADDITIONAL_HOSTS=

# Camera relay defaults
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30
CAMERA_STARTUP_TIMEOUT=20.0
CAMERA_RETRY_INTERVAL=0.5
